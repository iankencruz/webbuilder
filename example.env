OIDC_PROVIDERS=zitadel

OIDC_ZITADEL_ISSUER_URL=https://your-instance.zitadel.cloud
OIDC_ZITADEL_CLIENT_ID=your-client-id
OIDC_ZITADEL_CLIENT_SECRET=your-client-secret
OIDC_ZITADEL_REDIRECT_URL=http://localhost:8080/auth/zitadel/callback
OIDC_ZITADEL_SCOPES=openid,email,profile
OIDC_ZITADEL_POST_LOGIN_URL=http://localhost:5173/dashboard
